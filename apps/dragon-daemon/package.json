{
  "name": "@funeste38/dragon",
  "version": "0.2.0",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "description": "Dragon control-plane daemon for the Funesterie ecosystem.",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jEFFLEZ/dragon.git"
  },
  "bugs": {
    "url": "https://github.com/jEFFLEZ/dragon/issues"
  },
  "homepage": "https://github.com/jEFFLEZ/dragon#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@funeste38/dragon-contracts": "^0.2.0",
    "@funeste38/dragon-upstream": "^0.2.0",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.5"
  }
}
